{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "1Agents",
  "version": "0.1.0",
  "identifier": "com.oneagents.desktop",
  "build": {
    "frontendDist": "../html/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "1Agents",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
