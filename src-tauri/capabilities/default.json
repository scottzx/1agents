{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*/**",
      "http://localhost:*/**"
    ]
  },
  "permissions": [
    "core:default",
    "allow-browser-commands",
    "allow-updater",
    "updater:default",
    "process:default",
    "dialog:default"
  ]
}
